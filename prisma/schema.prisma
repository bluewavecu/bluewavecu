generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  ON_HOLD
  DISABLED
}

enum AccountType {
  CHECKING
  SAVINGS
  BUSINESS
  MONEY_MARKET
  CERTIFICATE
  CREDIT
}

enum AccountStatus {
  PENDING_APPROVAL
  ACTIVE
  FROZEN
  CLOSED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  PAYMENT
  CARD
  FEE
  REFUND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum CardType {
  DEBIT
  CREDIT
}

enum CardStatus {
  ACTIVE
  LOCKED
  CANCELLED
  EXPIRED
}

enum CardApplicationStatus {
  PENDING
  APPROVED
  DECLINED
}

enum IdDocumentType {
  DRIVERS_LICENSE
  PASSPORT
  STATE_ID
  NATIONAL_ID
}

enum IdVerificationStatus {
  PENDING
  APPROVED
  REJECTED
  DECLINED
}

enum LoanStatus {
  PENDING
  ACTIVE
  PAID_OFF
  DEFAULTED
  DENIED
}

enum SupportTicketStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum LedgerDirection {
  DEBIT
  CREDIT
}

enum NotificationType {
  SYSTEM
  TRANSFER
  ACCOUNT
  SECURITY
  SUPPORT
  ADMIN
}

enum ScheduledTransferFrequency {
  ONE_TIME
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum ScheduledTransferStatus {
  ACTIVE
  PAUSED
  CANCELLED
  COMPLETED
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MfaMethod {
  EMAIL
  SMS
  TOTP
}

enum PayeeStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum BillPaymentStatus {
  DRAFT
  SCHEDULED
  PENDING_REVIEW
  APPROVED
  FAILED
  CANCELLED
  POSTED
}

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum AdjustmentStatus {
  PENDING
  APPROVED
  SCHEDULED
  REJECTED
  POSTED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
  CLOSED
}

enum EventSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum KycStatus {
  NOT_STARTED
  SUBMITTED
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum TransferOtpStepKey {
  IDENTITY_CHECK
  AMOUNT_CONFIRMATION
  BENEFICIARY_VERIFICATION
  SECURITY_CLEARANCE
  FINAL_RELEASE
}

model User {
  id                       String          @id @default(cuid())
  fullName                 String
  username                 String          @unique
  email                    String          @unique
  phone                    String
  passwordHash             String
  role                     UserRole        @default(USER)
  status                   UserStatus      @default(PENDING)
  transactionsUnrestricted Boolean         @default(false)
  billPayPaused            Boolean         @default(false)
  transactionPinHash       String?
  statusNote               String?
  deletedAt                DateTime?
  emailVerifiedAt          DateTime?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  accounts            Account[]
  transactions        Transaction[]
  cards               Card[]
  loans               Loan[]
  supportTickets      SupportTicket[]
  adminAuditLogs      AdminAuditLog[] @relation("AdminAuditLogs")
  ledgerEntries       LedgerEntry[]
  notifications       Notification[]
  scheduledTransfers  ScheduledTransfer[]
  riskEvents          RiskEvent[]
  sessions            UserSession[]
  mfaSettings         MfaSetting[]
  payees              Payee[]
  billPayments        BillPayment[]
  adjustmentRequests  AdjustmentRequest[] @relation("MemberAdjustments")
  adminAdjustments    AdjustmentRequest[] @relation("AdminAdjustments")
  disputes            Dispute[]
  customerProfile     CustomerProfile?
  transactionOtps     TransactionOtp[]
  loginOtps           LoginOtp[]
  emailVerificationOtps EmailVerificationOtp[]
  trustedDevices      TrustedDevice[]
  cardApplications    CardApplication[]
  passwordResets      PasswordReset[]
  transactionPinResetOtps TransactionPinResetOtp[]
  idVerificationSubmissions IdVerificationSubmission[]
  transferOtpSteps      MemberTransferOtpStep[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([deletedAt])
  @@index([billPayPaused])
}

model Account {
  id               String        @id @default(cuid())
  userId           String
  accountType      AccountType
  accountNumber    String?       @unique
  routingNumber    String
  balance          Decimal       @default(0) @db.Decimal(14, 2)
  availableBalance Decimal       @default(0) @db.Decimal(14, 2)
  currency         String        @default("USD")
  status           AccountStatus @default(ACTIVE)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     Transaction[]
  cards            Card[]
  ledgerEntries    LedgerEntry[]
  scheduledTransfers ScheduledTransfer[]
  billPayments     BillPayment[]
  adjustmentRequests AdjustmentRequest[]
  cardApplications   CardApplication[]

  @@index([userId])
  @@index([accountType])
  @@index([status])
}

model Transaction {
  id                       String            @id @default(cuid())
  userId                   String
  accountId                String
  type                     TransactionType
  amount                   Decimal           @db.Decimal(14, 2)
  description              String
  merchant                 String?
  reference                String            @unique
  status                   TransactionStatus @default(PENDING)
  destinationAccountNumber String?
  postedAt                 DateTime?
  reviewedAt               DateTime?
  reviewedBy               String?
  reviewNote               String?
  delayedAt                DateTime?
  cardId                   String?
  createdAt                DateTime          @default(now())

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account        Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  card           Card?         @relation(fields: [cardId], references: [id], onDelete: SetNull)
  ledgerEntries  LedgerEntry[]
  billPayments   BillPayment[]
  disputes       Dispute[]
  adjustmentRequests AdjustmentRequest[]

  @@index([userId])
  @@index([accountId])
  @@index([cardId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([postedAt])
}

model Card {
  id             String     @id @default(cuid())
  userId         String
  accountId      String
  cardType       CardType
  last4          String
  panPrefix      String     @default("552901")
  network        String     @default("MASTERCARD")
  expiryMonth    Int?
  expiryYear     Int?
  cardholderName String
  status         CardStatus @default(ACTIVE)
  spendingLimit  Decimal    @default(0) @db.Decimal(14, 2)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  account        Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  application    CardApplication?
  transactions   Transaction[]

  @@index([userId])
  @@index([accountId])
  @@index([cardType])
  @@index([status])
}

model CardApplication {
  id             String                @id @default(cuid())
  userId         String
  accountId      String
  cardType       CardType
  cardholderName String
  email          String
  phone          String
  addressLine1   String
  addressLine2   String?
  city           String
  state          String
  postalCode     String
  country        String                @default("US")
  status         CardApplicationStatus @default(PENDING)
  reviewNote     String?
  reviewedAt     DateTime?
  reviewedBy     String?
  cardId         String?               @unique
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  card    Card?   @relation(fields: [cardId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([accountId])
  @@index([status])
  @@index([createdAt])
}

model Loan {
  id             String     @id @default(cuid())
  userId         String
  loanType       String
  principal      Decimal    @db.Decimal(14, 2)
  balance        Decimal    @db.Decimal(14, 2)
  interestRate   Decimal    @db.Decimal(5, 2)
  termMonths     Int
  monthlyPayment Decimal    @db.Decimal(14, 2)
  status         LoanStatus @default(PENDING)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([loanType])
  @@index([status])
}

model SupportTicket {
  id        String                @id @default(cuid())
  userId    String
  subject   String
  message   String
  status    SupportTicketStatus   @default(OPEN)
  priority  SupportTicketPriority @default(NORMAL)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([priority])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  entityType String
  entityId   String
  details    Json?
  createdAt  DateTime @default(now())

  admin      User     @relation("AdminAuditLogs", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

model LedgerEntry {
  id            String          @id @default(cuid())
  transactionId String
  accountId     String
  userId        String
  direction     LedgerDirection
  amount        Decimal         @db.Decimal(14, 2)
  currency      String          @default("USD")
  balanceBefore Decimal         @db.Decimal(14, 2)
  balanceAfter  Decimal         @db.Decimal(14, 2)
  description   String
  createdAt     DateTime        @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([transactionId, accountId, direction])
  @@index([transactionId])
  @@index([accountId])
  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

model ScheduledTransfer {
  id                       String                     @id @default(cuid())
  userId                   String
  fromAccountId            String
  recipientName            String?
  destinationAccountNumber String?
  amount                   Decimal                    @db.Decimal(14, 2)
  memo                     String?
  frequency                ScheduledTransferFrequency
  scheduledFor             DateTime
  nextRunAt                DateTime
  status                   ScheduledTransferStatus    @default(ACTIVE)
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt

  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAccount Account @relation(fields: [fromAccountId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([fromAccountId])
  @@index([status])
  @@index([nextRunAt])
  @@index([scheduledFor])
}

model RiskEvent {
  id        String       @id @default(cuid())
  userId    String
  eventType String
  riskScore Int
  severity  RiskSeverity
  reason    String
  metadata  Json?
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventType])
  @@index([severity])
  @@index([createdAt])
}

model UserSession {
  id         String    @id @default(cuid())
  userId     String
  tokenId    String    @unique
  deviceName String
  ipAddress  String
  userAgent  String
  location   String?
  isActive   Boolean   @default(true)
  lastSeenAt DateTime  @default(now())
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@index([lastSeenAt])
  @@index([createdAt])
}

model MfaSetting {
  id         String    @id @default(cuid())
  userId     String
  method     MfaMethod
  isEnabled  Boolean   @default(false)
  secret     String?
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, method])
  @@index([userId])
  @@index([isEnabled])
}

model Payee {
  id            String      @id @default(cuid())
  userId        String
  name          String
  nickname      String?
  category      String?
  accountNumber String?
  routingNumber String?
  address       String?
  phone         String?
  status        PayeeStatus @default(ACTIVE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  billPayments BillPayment[]

  @@index([userId])
  @@index([status])
  @@index([name])
}

model BillPayment {
  id            String            @id @default(cuid())
  userId        String
  fromAccountId String
  payeeId       String
  amount        Decimal           @db.Decimal(14, 2)
  memo          String?
  dueDate       DateTime?
  scheduledFor  DateTime?
  status        BillPaymentStatus @default(DRAFT)
  transactionId String?           @unique
  riskScore     Int?
  reviewedAt    DateTime?
  reviewedBy    String?
  reviewNote    String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAccount Account      @relation(fields: [fromAccountId], references: [id], onDelete: Cascade)
  payee       Payee        @relation(fields: [payeeId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([fromAccountId])
  @@index([payeeId])
  @@index([status])
  @@index([dueDate])
  @@index([scheduledFor])
  @@index([createdAt])
}

model JobQueue {
  id          String    @id @default(cuid())
  jobType     String
  status      JobStatus @default(QUEUED)
  runAt       DateTime
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  payload     Json
  error       String?
  lockedAt    DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([jobType])
  @@index([status])
  @@index([runAt])
  @@index([createdAt])
}

model AdjustmentRequest {
  id            String            @id @default(cuid())
  accountId     String
  userId        String
  adminId       String
  amount        Decimal           @db.Decimal(14, 2)
  direction     LedgerDirection
  reason        String
  status        AdjustmentStatus  @default(PENDING)
  reviewedAt    DateTime?
  postedAt      DateTime?
  reviewNote    String?
  effectiveAt   DateTime          @default(now())
  transactionId String?           @unique
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  account     Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user        User         @relation("MemberAdjustments", fields: [userId], references: [id], onDelete: Cascade)
  admin       User         @relation("AdminAdjustments", fields: [adminId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([userId])
  @@index([adminId])
  @@index([status])
  @@index([createdAt])
  @@index([effectiveAt])
}

model Dispute {
  id              String        @id @default(cuid())
  userId          String
  transactionId   String
  reason          String
  description     String
  status          DisputeStatus @default(OPEN)
  resolutionNote  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([transactionId])
  @@index([status])
  @@index([createdAt])
}

model EventLog {
  id         String        @id @default(cuid())
  eventType  String
  actorId    String?
  entityType String
  entityId   String?
  severity   EventSeverity @default(INFO)
  message    String
  metadata   Json?
  createdAt  DateTime      @default(now())

  @@index([eventType])
  @@index([actorId])
  @@index([entityType])
  @@index([entityId])
  @@index([severity])
  @@index([createdAt])
}

model IdVerificationSubmission {
  id            String               @id @default(cuid())
  userId        String
  documentType  IdDocumentType
  frontPhotoUrl String
  backPhotoUrl  String?
  status        IdVerificationStatus @default(PENDING)
  reviewNote    String?
  reviewedAt    DateTime?
  reviewedBy    String?
  submittedAt   DateTime             @default(now())
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([submittedAt])
}

model CustomerProfile {
  id               String    @id @default(cuid())
  userId           String    @unique
  dateOfBirth      DateTime?
  addressLine1     String?
  addressLine2     String?
  city             String?
  state            String?
  postalCode       String?
  country          String?   @default("US")
  employmentStatus String?
  annualIncome     Decimal?  @db.Decimal(14, 2)
  kycStatus        KycStatus @default(NOT_STARTED)
  kycSubmittedAt   DateTime?
  kycReviewedAt    DateTime?
  kycReviewedBy    String?
  kycReviewNote    String?
  profilePhotoUrl  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([kycStatus])
  @@index([createdAt])
}

model TransactionOtp {
  id         String    @id @default(cuid())
  userId     String
  codeHash   String
  payload    Json
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model MemberTransferOtpStep {
  id        String             @id @default(cuid())
  userId    String
  stepKey   TransferOtpStepKey
  enabled   Boolean            @default(false)
  code      String?
  updatedAt DateTime           @updatedAt
  updatedBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stepKey])
  @@index([userId])
  @@index([enabled])
}

model LoginOtp {
  id          String    @id @default(cuid())
  userId      String
  codeHash    String
  deviceToken String
  deviceName  String
  userAgent   String
  ipAddress   String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationOtp {
  id         String    @id @default(cuid())
  userId     String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model TrustedDevice {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String
  deviceName String
  userAgent  String
  ipAddress  String
  lastUsedAt DateTime  @default(now())
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tokenHash])
  @@index([userId])
  @@index([lastUsedAt])
}

model BankingPolicy {
  id                    String   @id @default("default")
  requireTransactionOtp Boolean  @default(true)
  requireTransferReview   Boolean  @default(true)
  updatedAt             DateTime @updatedAt
  updatedBy             String?
}

model PasswordReset {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model TransactionPinResetOtp {
  id         String    @id @default(cuid())
  userId     String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
