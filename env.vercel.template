# Bluewave CU — Vercel environment variables template
# Copy to .env.vercel (gitignored) or paste into Vercel Dashboard → Settings → Environment Variables
#
# Generate fresh secrets locally:
#   JWT_SECRET:  openssl rand -base64 48
#   CRON_SECRET: openssl rand -hex 32
#
# Still required from you (or auto-injected by Vercel Supabase integration):
#   DATABASE_URL      — optional if POSTGRES_PRISMA_URL is set (Prisma uses either)
#   POSTGRES_PRISMA_URL — injected by Vercel + Supabase integration
#   RESEND_API_KEY    — from resend.com
#   ADMIN_ALERT_EMAIL — admin inbox for alerts

DATABASE_URL=
JWT_SECRET=
NEXT_PUBLIC_APP_URL=https://bluewavecu.com
NODE_ENV=production
ALLOW_DEMO_SEED=false
RESEND_API_KEY=
EMAIL_FROM=Bluewave Credit Union <no-reply@bluewavecu.com>
ADMIN_ALERT_EMAIL=
CRON_SECRET=
