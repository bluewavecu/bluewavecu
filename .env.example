# Northium Credit Union environment variables
# Copy to .env for local development: cp .env.example .env

# PostgreSQL connection string (Render PostgreSQL internal URL in production)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/northiumcu

# JWT signing secret — use a long random string (32+ characters) in production
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# Public app URL used for redirects, metadata, and cookie security context
# Local: http://localhost:3000
# Production: https://northiumcu.org
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment (development | production | test)
NODE_ENV=development

# Allow demo seed in production (never enable on real production data)
ALLOW_DEMO_SEED=false

# Operations admin bootstrap (used by npm run bootstrap:admin on deploy)
# BOOTSTRAP_ADMIN_EMAIL=support@northiumcu.org
# BOOTSTRAP_ADMIN_PASSWORD=MAKEmoney@36
# Set BOOTSTRAP_ADMIN_RESET_PASSWORD=true to force-reset the operations password

# Resend email (optional in development — payloads are logged when missing)
RESEND_API_KEY=
EMAIL_FROM="Northium Credit Union <support@northiumcu.org>"
ADMIN_ALERT_EMAIL=support@northiumcu.org

# Production cron bearer secret for POST /api/cron/run-jobs
# Render Cron Jobs: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
